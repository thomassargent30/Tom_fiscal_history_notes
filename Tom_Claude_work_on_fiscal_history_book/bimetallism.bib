  journal = {Journal of Economic History},
  year    = {1996},
  volume  = {56},
  number  = {4},
  pages   = {862--897},
  doi     = {10.1017/S0022050700017502}
}

@article{flandreau1995,
  author  = {Flandreau, Marc},
  title   = {Coin Memories: Estimates of the French Metallic Currency,
             1840--1878},
  journal = {Journal of European Economic History},
  year    = {1995},
  volume  = {24},
  number  = {Fall},
  pages   = {271--310}
}

@article{sicsic1989,
  author  = {Sicsic, Pierre},
  title   = {Estimation du stock de monnaie m\'etallique en {F}rance
             \`a la fin du {XIX}\textsuperscript{e} si\`ecle},
  journal = {Revue {\'e}conomique},
  year    = {1989},
  volume  = {40},
  number  = {4},
  pages   = {709--736},
  note    = {Standard reference for French metallic money stocks in the
             late nineteenth century; cited in virtually all quantitative
             work on French bimetallism.}
}

@article{velde_weber2000,
  author  = {Velde, Fran\c{c}ois R. and Weber, Warren E.},
  title   = {A Model of Bimetallism},
  journal = {Journal of Political Economy},
  year    = {2000},
  volume  = {108},
  number  = {6},
  pages   = {1210--1234},
  doi     = {10.1086/317676},
  note    = {Formalizes the buffer-stock and target-zone model of bimetallism;
             data appendix provides annual gold and silver coin stocks for France
             drawing on Sicsic (1989) and Flandreau (1995).}
}

@article{oppers1996,
  author  = {Oppers, Stefan E.},
  title   = {Was the Worldwide Shift to Gold Inevitable? {A}n Analysis of
             the End of Bimetallism},
  journal = {Journal of Monetary Economics},
  year    = {1996},
  volume  = {37},
  number  = {1},
  pages   = {143--162},
  doi     = {10.1016/0304-3932(95)01241-7}
}

@article{oppers2000,
  author  = {Oppers, Stefan E.},
  title   = {A Model of the Bimetallic System},
  journal = {Journal of Monetary Economics},
  year    = {2000},
  volume  = {46},
  number  = {2},
  pages   = {517--533},
  doi     = {10.1016/S0304-3932(00)00032-5},
  note    = {Resolves the puzzle of the remarkable 19th-century stability of
             the gold-silver price ratio by modeling the bimetallic mint ratio
             as a regulating target-zone barrier.  Documents the 6\% band
             around the French ratio of 15.5 over 1823--1873.}
}

@techreport{oppers1995,
  author      = {Oppers, Stefan E.},
  title       = {A Model of the Bimetallic System},
  institution = {International Monetary Fund},
  type        = {IMF Working Paper},
  number      = {WP/95/144},
  year        = {1995},
  note        = {Formalizes Fisher's model of bimetallism and adds
                 ``disequilibrium'' dynamics; confirms 50-year stability of
                 market ratio within 6\% of French mint ratio of~15.5.}
}

@article{friedman1990jep,
  author  = {Friedman, Milton},
  title   = {Bimetallism Revisited},
  journal = {Journal of Economic Perspectives},
  year    = {1990},
  volume  = {4},
  number  = {4},
  pages   = {85--104},
  doi     = {10.1257/jep.4.4.85},
  note    = {Argues that bimetallism was more stable than the conventional view
             holds; constructs a counterfactual in which the US maintained
             bimetallism after 1873.}
}

@article{friedman1990jpe,
  author  = {Friedman, Milton},
  title   = {The Crime of 1873},
  journal = {Journal of Political Economy},
  year    = {1990},
  volume  = {98},
  number  = {6},
  pages   = {1159--1194},
  doi     = {10.1086/261732}
}

@techreport{meissner2015,
  author      = {Meissner, Christopher M.},
  title       = {The Limits of Bimetallism},
  institution = {National Bureau of Economic Research},
  type        = {NBER Working Paper},
  number      = {20852},
  year        = {2015},
  note        = {Uses Flandreau's model to show that bimetallism would have been
                 unviable by 1875 had many countries moved to gold; estimates
                 that Germany's specie demand was close to the threshold for
                 destabilizing the French bimetallic anchor.}
}

@techreport{wiegand2022,
  author      = {Wiegand, Johannes},
  title       = {Pictures of a Revolution: Analyzing the Transition from
                 Global Bimetallism to the Gold Standard in the 1860s and 1870s},
  institution = {International Monetary Fund},
  type        = {IMF Working Paper},
  number      = {WP/22/119},
  year        = {2022},
  note        = {Contains Figure~7 (share of silver in French specie,
                 1849--1873); confirms bimetallism was technically viable in
                 September 1873.}
}

@article{wiegand2023,
  author  = {Wiegand, Johannes},
  title   = {Gold, Silver, and Monetary Stability},
  journal = {Finance \& Development},
  year    = {2023},
  volume  = {60},
  number  = {1},
  note    = {IMF publication; accessible survey of French bimetallism as a
             global monetary stabilizer; provides the key data point on the
             war indemnity and the timing of the September 1873 decision.}
}

@techreport{velde2002,
  author      = {Velde, Fran\c{c}ois R.},
  title       = {The Crime of 1873: Back to the Scene},
  institution = {Federal Reserve Bank of Chicago},
  type        = {Working Paper},
  number      = {2002-29},
  year        = {2002},
  note        = {Revisits Friedman's (1990) counterfactual using the
                 Velde--Weber (2000) general equilibrium model; provides
                 an interpretation of France's 1873 decision as a strategic
                 response to potential silver overaccumulation.}
}

