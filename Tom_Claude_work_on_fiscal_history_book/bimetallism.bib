  title     = {The Glitter of Gold: France, Bimetallism, and the Emergence
               of the International Gold Standard, 1848--1873},
  publisher = {Oxford University Press},
  address   = {Oxford},
  year      = {2004},
  note      = {Contains Chapter~4 (``Coin Memories'') with new estimates of
               France's specie stock 1840--1878 and the definitive appendix
